// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MediaType {
  AUDIO
  IMAGE
  VIDEO
  OTHER
}

model Media {
  id               String    @id @default(uuid()) @db.Uuid
  title            String
  description      String?
  tags             String[]  @default([])
  mediaType        MediaType
  mimeType         String
  originalFilename String
  storedFilename   String    @unique
  storagePath      String
  sizeBytes        BigInt
  checksum         String
  durationSeconds  Float?
  width            Int?
  height           Int?
  createdBy        String?
  metadata         Json      @default("{}")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Lifecycle management
  status           String    @default("active")
  staleReason      String?
  staleAt          DateTime?
  staleBy          String?
  expiresAt        DateTime?

  // Starcast content identity
  contentType      String?
  stationId        String?

  // Agent traceability
  generatedBy      String?
  runId            String?

  @@index([mediaType])
  @@index([createdAt])
  @@index([checksum])
  @@index([status])
  @@index([contentType])
  @@index([stationId])
  @@index([expiresAt])
  @@index([contentType, stationId, status])
  @@map("media")
}
